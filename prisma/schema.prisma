generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String          @id @default(cuid())
  name         String
  email        String          @unique
  passwordHash String
  createdAt    DateTime        @default(now())
  sessions     ImportSession[]
  transactions Transaction[]
  debtors      Debtor[]
}

model Debtor {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String
  whatsapp  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, name])
  @@index([userId])
}

model ImportSession {
  id           String        @id @default(cuid())
  userId       String
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  month        String
  source       String
  inputType    String
  createdAt    DateTime      @default(now())
  transactions Transaction[]
}

model Transaction {
  id              String        @id @default(cuid())
  importSessionId String
  importSession   ImportSession @relation(fields: [importSessionId], references: [id], onDelete: Cascade)
  userId          String
  user            User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  date                DateTime
  description         String
  amountCents         Int
  isCredit            Boolean  @default(false)
  isCharge            Boolean  @default(false)
  installmentCurrent  Int?
  installmentTotal    Int?
  currencyOriginal    String?
  amountOriginalCents Int?
  sourceType          String
  rawLine             String?
  externalIdentifier  String?
  origin              String        @default("imported")
  reconciledAt        DateTime?

  status          String             @default("pending")
  transactionType String?
  debtorName      String?
  splitMode       String             @default("none")
  category        String?
  subcategory     String?
  notes           String?
  isEssential     Boolean?
  splits          TransactionSplit[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, importSessionId])
  @@index([userId, date])
  @@index([userId, status, description])
  @@unique([userId, sourceType, externalIdentifier])
}

model TransactionSplit {
  id            String      @id @default(cuid())
  transactionId String
  transaction   Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  userId        String
  debtorName    String
  amountCents   Int
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@index([userId, debtorName])
  @@index([transactionId])
}
