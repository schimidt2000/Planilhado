generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id             String          @id @default(cuid())
  name           String
  email          String          @unique
  passwordHash   String
  createdAt      DateTime        @default(now())
  sessions       ImportSession[]
  transactions   Transaction[]
  debtors        Debtor[]
  debtorPayments DebtorPayment[]
  preferences    UserPreference?
  salaryEntries  SalaryEntry[]
  billReminders  BillReminder[]
  extraIncomes   ExtraIncome[]
}

model UserPreference {
  id                String   @id @default(cuid())
  userId            String   @unique
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  showDashboardTips Boolean  @default(true)
  showReviewTips    Boolean  @default(true)
  showUploadTips    Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model SalaryEntry {
  id             String   @id @default(cuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  effectiveMonth String
  amountCents    Int
  notes          String?
  createdAt      DateTime @default(now())

  @@index([userId, effectiveMonth])
}

model BillReminder {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  label     String
  source    String?
  dueDay    Int
  active    Boolean  @default(true)
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, active])
}

model ExtraIncome {
  id           String    @id @default(cuid())
  userId       String
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  description  String
  amountCents  Int
  expectedDate DateTime
  status       String    @default("planned")
  receivedAt   DateTime?
  notes        String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([userId, expectedDate])
  @@index([userId, status])
}

model Debtor {
  id           String             @id @default(cuid())
  userId       String
  user         User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  name         String
  whatsapp     String?
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt
  payments     DebtorPayment[]
  transactions Transaction[]      @relation("TransactionDebtor")
  splits       TransactionSplit[] @relation("TransactionSplitDebtor")

  @@unique([userId, name])
  @@index([userId])
}

model DebtorPayment {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  debtorId    String
  debtor      Debtor   @relation(fields: [debtorId], references: [id], onDelete: Cascade)
  month       String
  amountCents Int
  paidAt      DateTime
  notes       String?
  createdAt   DateTime @default(now())

  @@index([userId, month])
  @@index([debtorId, month])
}

model ImportSession {
  id             String        @id @default(cuid())
  userId         String
  user           User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  month          String
  source         String
  inputType      String
  fileName       String?
  fileSize       Int?
  fileHash       String?
  newCount       Int           @default(0)
  completedCount Int           @default(0)
  duplicateCount Int           @default(0)
  createdAt      DateTime      @default(now())
  transactions   Transaction[]

  @@index([userId, month])
  @@index([userId, fileHash])
}

model Transaction {
  id              String        @id @default(cuid())
  importSessionId String
  importSession   ImportSession @relation(fields: [importSessionId], references: [id], onDelete: Cascade)
  userId          String
  user            User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  date                DateTime
  description         String
  amountCents         Int
  isCredit            Boolean   @default(false)
  isCharge            Boolean   @default(false)
  installmentCurrent  Int?
  installmentTotal    Int?
  currencyOriginal    String?
  amountOriginalCents Int?
  sourceType          String
  cardLastFour        String?
  rawLine             String?
  externalIdentifier  String?
  origin              String    @default("imported")
  reconciledAt        DateTime?

  status          String             @default("pending")
  transactionType String?
  debtorId        String?
  debtor          Debtor?            @relation("TransactionDebtor", fields: [debtorId], references: [id], onDelete: SetNull)
  debtorName      String?
  splitMode       String             @default("none")
  category        String?
  subcategory     String?
  notes           String?
  isEssential     Boolean?
  splits          TransactionSplit[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, sourceType, externalIdentifier])
  @@index([userId, importSessionId])
  @@index([userId, date])
  @@index([userId, status, description])
  @@index([userId, cardLastFour])
  @@index([userId, debtorId])
}

model TransactionSplit {
  id            String      @id @default(cuid())
  transactionId String
  transaction   Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  userId        String
  debtorId      String?
  debtor        Debtor?     @relation("TransactionSplitDebtor", fields: [debtorId], references: [id], onDelete: SetNull)
  debtorName    String
  amountCents   Int
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@index([userId, debtorName])
  @@index([userId, debtorId])
  @@index([transactionId])
}
